# ---------------------------------------------------------------------------
# Wiki data — excluded by default to prevent accidental publishing.
# If you want to back up your wiki in this repo, remove this section.
# ---------------------------------------------------------------------------

# Obsidian vault config
.obsidian/

# Wiki content and processed sources (keep directory stubs via .gitkeep)
wiki/*
!wiki/.gitkeep
inbox/*
!inbox/.gitkeep
raw/*
!raw/.gitkeep
artifacts/*
!artifacts/.gitkeep

# Claude Code local config (auth tokens, session history — not for VCS)
.claude/
.claude.json
